{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "card.schema.json",
	"title": "Fractured Arcana Card",
	"description": "Schema for card JSON files in Data/Cards/. Validates card structure, halves, targeting, and effects.",
	"type": "object",
	"required": [
		"id",
		"name",
		"school",
		"rarity",
		"status"
	],
	"additionalProperties": false,
	"properties": {
		"id": {
			"type": "string",
			"description": "Unique card identifier. Convention: schoolname_cardname in lowercase with underscores.",
			"pattern": "^[a-z][a-z0-9_]*$",
			"examples": [
				"elementalist_fireball",
				"necromancer_bone_spike"
			]
		},
		"name": {
			"type": "string",
			"description": "Display name shown in the UI.",
			"minLength": 1
		},
		"school": {
			"type": "string",
			"description": "Wizard school this card belongs to. Must match the CardSchool enum exactly.",
			"enum": [
				"Elementalist",
				"Arcanist",
				"Necromancer",
				"Enchanter",
				"Artificer",
				"Chronomancer",
				"Tinker",
				"Generic"
			]
		},
		"rarity": {
			"type": "string",
			"description": "Card rarity tier.",
			"enum": [
				"Common",
				"Uncommon",
				"Rare",
				"Legendary"
			]
		},
		"status": {
			"type": "string",
			"description": "Controls whether this card is loaded into the game. Required on every card — no card may exist without a declared status.\n\n  'ready' — Fully built and integrated. Loads into CardDatabase normally. Appears in CardLibrary and is draftable.\n  'wip'   — Built but not yet balanced or fully tested. Loads only when DevMode is enabled in CardLoaderV2. Does not appear in CardLibrary.\n  'stub'  — Placeholder only. Never loaded regardless of build mode. Effect chains may be empty or missing.",
			"enum": [
				"ready",
				"wip",
				"stub"
			]
		},
		"top": {
			"$ref": "#/$defs/CardHalf"
		},
		"bottom": {
			"$ref": "#/$defs/CardHalf"
		}
	},
	"$defs": {
		"CardHalf": {
			"type": "object",
			"description": "One playable half of a card (top or bottom).",
			"required": [
				"name",
				"mana",
				"speed",
				"rules_text",
				"tags",
				"targeting",
				"effect"
			],
			"additionalProperties": false,
			"properties": {
				"name": {
					"type": "string",
					"description": "Display name for this half.",
					"minLength": 1
				},
				"mana": {
					"type": "integer",
					"description": "Mana cost to play this half.",
					"minimum": 0,
					"maximum": 10
				},
				"speed": {
					"type": "string",
					"description": "When this half can be played.",
					"enum": [
						"Sorcery",
						"Instant",
						"Reaction"
					]
				},
				"rules_text": {
					"type": "string",
					"description": "Human-readable description of the effect shown on the card.",
					"minLength": 1
				},
				"tags": {
					"type": "array",
					"description": "Element and school tags read at cast time by attunement, buff systems, and targeting selectors. Required on every half — use an empty array [] for halves with no elemental or school identity. Tag strings are open-ended; new schools and mechanics will introduce new values over time without requiring schema changes.",
					"items": {
						"type": "string",
						"minLength": 1
					}
				},
				"requires": {
					"type": "array",
					"description": "Pre-cast validation checks. Card cannot be played unless all conditions are met.",
					"items": {
						"type": "string",
						"enum": [
							"fire_tile",
							"ice_tile",
							"storm_tile",
							"stone_tile",
							"empty_tile",
							"ally_adjacent",
							"enemy_adjacent"
						]
					}
				},
				"targeting": {
					"$ref": "#/$defs/Targeting"
				},
				"effect": {
					"$ref": "#/$defs/Effect"
				},
				"channel": {
					"$ref": "#/$defs/ChannelVariant",
					"description": "Optional channeled version of this half. Played as a Reaction in response to the base half."
				}
			}
		},
		"ChannelVariant": {
			"type": "object",
			"description": "The channeled variant of a card half. Same structure as CardHalf but nested and optional.",
			"required": [
				"name",
				"mana",
				"speed",
				"rules_text",
				"tags",
				"targeting",
				"effect"
			],
			"additionalProperties": false,
			"properties": {
				"name": {
					"type": "string",
					"minLength": 1
				},
				"mana": {
					"type": "integer",
					"minimum": 0,
					"maximum": 10
				},
				"speed": {
					"type": "string",
					"enum": [
						"Sorcery",
						"Instant",
						"Reaction"
					]
				},
				"rules_text": {
					"type": "string",
					"minLength": 1
				},
				"tags": {
					"type": "array",
					"description": "Element and school tags. Required — use [] if this channel variant has no elemental identity.",
					"items": {
						"type": "string",
						"minLength": 1
					}
				},
				"requires": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"targeting": {
					"$ref": "#/$defs/Targeting"
				},
				"effect": {
					"$ref": "#/$defs/Effect"
				}
			}
		},
		"Targeting": {
			"type": "object",
			"description": "Targeting strategy for this card half.",
			"required": [
				"type"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"type": "string",
					"minLength": 1,
					"enum": [
						"self",
						"range",
						"aoe",
						"line",
						"cone",
						"ring",
						"adjacent",
						"tile",
						"unit",
						"nearest_to_target",
						"adjacent_to_target",
						"element_tile",
						"imbued_tile"
					]
				},
				"range": {
					"type": "integer",
					"minimum": 1
				},
				"radius": {
					"type": "integer",
					"minimum": 1
				},
				"length": {
					"type": "integer",
					"minimum": 1
				},
				"enemies_only": {
					"type": "boolean"
				},
				"allies_only": {
					"type": "boolean"
				},
				"los": {
					"type": "boolean"
				},
				"include_tiles": {
					"type": "boolean"
				},
				"element": {
					"type": "string",
					"minLength": 1
				}
			}
		},
		"Effect": {
			"type": "object",
			"description": "An effect node — leaf or composite. Must always have a non-empty 'type'. An effect object with no type or with type:'' is invalid and will be flagged here before it silently becomes an EmptyEffect at runtime. If an effect is not yet authored, mark the card status as 'stub' or 'wip' rather than leaving type blank.",
			"required": [
				"type"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"type": "string",
					"minLength": 1,
					"description": "Effect type key. Lowercase. Must be registered in CardScriptRegistry.RegisterBuiltins().",
					"examples": [
						"damage",
						"heal",
						"armor",
						"shield",
						"self_damage",
						"mana_gain",
						"apply_status",
						"imbue_tile",
						"imbue_area",
						"push",
						"push_damage",
						"imbue_path",
						"remove_armor",
						"consume_element_tile",
						"terraform",
						"elemental_convergence",
						"primordial_surge",
						"cataclysm",
						"ragnarok",
						"avatar_transform",
						"create_maelstrom",
						"create_rubble",
						"summon",
						"sequence",
						"conditional",
						"retarget"
					]
				},
				"amount": {
					"type": "integer",
					"minimum": 0
				},
				"radius": {
					"type": "integer",
					"minimum": 1
				},
				"damage": {
					"type": "integer",
					"minimum": 0
				},
				"damage_per_element": {
					"type": "integer",
					"minimum": 0
				},
				"damage_per_tile": {
					"type": "integer",
					"minimum": 0
				},
				"bonus_damage": {
					"type": "integer",
					"minimum": 0
				},
				"element": {
					"type": "string",
					"minLength": 1
				},
				"tiles": {
					"type": "integer",
					"minimum": 1,
					"description": "Tiles to push. NOTE: this is 'tiles' not 'amount' — a common typo source."
				},
				"collision_damage": {
					"type": "integer",
					"minimum": 0
				},
				"turns": {
					"type": "integer",
					"minimum": 1
				},
				"bonus_speed": {
					"type": "integer",
					"minimum": 0
				},
				"armor": {
					"type": "integer",
					"minimum": 0
				},
				"freezes": {
					"type": "boolean"
				},
				"half_to_allies": {
					"type": "boolean"
				},
				"attunement_counters": {
					"type": "integer",
					"minimum": 0,
					"maximum": 4
				},
				"cards_per_tiles": {
					"type": "integer",
					"minimum": 1
				},
				"move": {
					"type": "integer",
					"minimum": 0
				},
				"armor_per_tile": {
					"type": "integer",
					"minimum": 0
				},
				"unit_id": {
					"type": "string",
					"minLength": 1
				},
				"status": {
					"type": "string",
					"description": "Status effect to apply. Used by: apply_status.",
					"enum": [
						"burn",
						"frozen",
						"slowed",
						"stunned",
						"rooted",
						"poisoned",
						"weakened"
					]
				},
				"duration": {
					"type": "integer",
					"minimum": 1
				},
				"steps": {
					"type": "array",
					"description": "Ordered child effects. Used by: sequence.",
					"items": {
						"$ref": "#/$defs/Effect"
					},
					"minItems": 1
				},
				"if": {
					"$ref": "#/$defs/Predicate"
				},
				"then": {
					"$ref": "#/$defs/Effect"
				},
				"else": {
					"$ref": "#/$defs/Effect"
				},
				"targeting": {
					"$ref": "#/$defs/Targeting"
				},
				"do": {
					"$ref": "#/$defs/Effect"
				}
			}
		},
		"Predicate": {
			"type": "object",
			"description": "A boolean condition for use in conditional effects.",
			"required": [
				"type"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"type": "string",
					"minLength": 1
				},
				"element": {
					"type": "string",
					"minLength": 1
				},
				"status": {
					"type": "string",
					"minLength": 1
				},
				"element_tag": {
					"type": "string",
					"minLength": 1
				},
				"threshold": {
					"type": "integer",
					"minimum": 1,
					"maximum": 4
				}
			}
		}
	}
}